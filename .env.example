PORT=3001
NODE_ENV=development

# Prefer a single connection string (Render PostgreSQL provides DATABASE_URL)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/analytics

# Or discrete fields (used when DATABASE_URL is unset)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=root
DB_NAME=analytics

# Use a long random string in production (32+ characters)
JWT_SECRET=change_me_use_openssl_rand_base64_32_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d

# Comma-separated origins for CORS (Vercel production + preview URLs)
# Example: https://app.vercel.app,https://*.vercel.app is NOT supported by Express;
# list each preview host explicitly or use FRONTEND_URL for single origin.
CORS_ORIGIN=http://localhost:3000

# Optional alias read by main.ts if CORS_ORIGIN is unset
# FRONTEND_URL=http://localhost:3000

# Dev only: force TypeORM synchronize (default: true when NODE_ENV !== production)
# TYPEORM_SYNCHRONIZE=true

# Production on Render: set NODE_ENV=production and TYPEORM_SYNCHRONIZE=false, then run migrations.
